# Safe default: complete UI and generation flow with local demo assets.
SHOWRUNNER_PROVIDER=mock

# Switch to qwen only when you intend to make real provider calls.
# SHOWRUNNER_PROVIDER=qwen

# Singapore-region Alibaba Cloud Model Studio credentials. Never expose these
# to browser code or commit a populated .env file.
QWEN_API_KEY=replace-with-your-singapore-api-key
QWEN_WORKSPACE_ID=replace-with-your-workspace-id

# Existing aliases are accepted for compatibility with the working experiment:
# DASHSCOPE_API_KEY=replace-with-your-singapore-api-key
# QWEN_CLOUD_API_KEY=replace-with-your-singapore-api-key
# QWEN_CLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model defaults preserve the successful keyframe-first media pipeline.
QWEN_TEXT_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen3-vl-plus
QWEN_IMAGE_MODEL=qwen-image-2.0
QWEN_IMAGE_EDIT_MODEL=qwen-image-2.0-pro
QWEN_VIDEO_MODEL=wan2.7-i2v
QWEN_REGION=ap-southeast-1

# Bounded production controls.
MAX_SHOTS=6
DEFAULT_SHOTS=3
MAX_VIDEO_DURATION_SECONDS=5
MAX_PROJECT_RETRIES=3
MAX_CONCURRENT_VIDEO_TASKS=2

# Persistent runtime paths (mount /app/data in production).
VIDEOFORGE_DATABASE=data/videoforge.db
VIDEOFORGE_ASSET_ROOT=data/assets

# Optional pricing overrides, used only for visible estimates.
QWEN_IMAGE_COST_CNY=0.256873
QWEN_VIDEO_COST_CNY_PER_SECOND_720P=0.733924
